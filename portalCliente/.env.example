# ============================================================
# Portal Cliente — Variables de entorno
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# --- Supabase ---------------------------------------------------
# Obten estos valores en: https://supabase.com/dashboard/project/_/settings/api

# URL del proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública (anon) — segura para frontend con RLS activo
# ⚠️  NUNCA uses la service_role key aquí
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- App --------------------------------------------------------
# Ambiente: development | production
VITE_APP_ENV=development
